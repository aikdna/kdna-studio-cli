{
  "name": "@aikdna/kdna-studio-cli",
  "version": "0.3.2",
  "description": "Official KDNA Studio command-line authoring entry for creating, locking, compiling, and exporting trusted .kdna assets.",
  "type": "commonjs",
  "bin": {
    "kdna-studio": "bin/kdna-studio.js"
  },
  "files": [
    "bin/",
    "src/",
    "tests/",
    "README.md"
  ],
  "scripts": {
    "lint": "node --check bin/kdna-studio.js && node --check tests/cli.test.js",
    "test": "node --test tests/*.test.js",
    "test:all": "npm run lint && npm test"
  },
  "keywords": [
    "kdna",
    "kdna-studio",
    "kdna-studio-cli",
    "authoring",
    "human-lock",
    "judgment-cards"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna-studio-cli.git"
  },
  "homepage": "https://aikdna.com",
  "bugs": {
    "url": "https://github.com/aikdna/kdna-studio-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aikdna/kdna-studio-core": "^1.5.0"
  },
  "devDependencies": {
    "@aikdna/kdna-core": "^0.7.1"
  }
}
