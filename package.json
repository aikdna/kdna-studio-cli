{
  "name": "@aikdna/kdna-studio-cli",
  "version": "0.8.6",
  "description": "Official KDNA Studio command-line authoring entry for creating, reviewing, compiling, and exporting .kdna judgment assets through the KDNA toolchain.",
  "type": "commonjs",
  "bin": {
    "kdna-studio": "bin/kdna-studio.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "lint": "node --check bin/kdna-studio.js && node --check tests/cli.test.js",
    "test": "node --test tests/*.test.js",
    "test:all": "npm run lint && npm test",
    "release:check": "node scripts/release-check.js",
    "prepublishOnly": "npm test && npm run release:check"
  },
  "keywords": [
    "kdna",
    "kdna-studio",
    "kdna-studio-cli",
    "authoring",
    "provenance",
    "judgment-cards"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna-studio-cli.git"
  },
  "homepage": "https://aikdna.com",
  "bugs": {
    "url": "https://github.com/aikdna/kdna-studio-cli/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aikdna/kdna-studio-core": "^1.7.5",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cbor-x": "^1.6.4"
  },
  "devDependencies": {
    "@aikdna/kdna-core": "^0.15.0"
  }
}
